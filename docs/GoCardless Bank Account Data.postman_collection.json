  },
  "item": [
    {
      "name": "1 - Obtener Access Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "if (response.access) {",
              "  pm.collectionVariables.set(\"access_token\", response.access);",
              "  console.log(\"Access token guardado en collectionVariables\");",
              "} else {",
              "  console.log(\"No se ha encontrado access token en la respuesta\");",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"secret_id\": \"{{SECRET_ID}}\",\n  \"secret_key\": \"{{SECRET_KEY}}\"\n}"
        },
        "url": {
          "raw": "https://bankaccountdata.gocardless.com/api/v2/token/new/",
          "protocol": "https",
          "host": [
            "bankaccountdata",
            "gocardless",
            "com"
          ],
          "path": [
            "api",
            "v2",
            "token",
            "new",
            ""
          ]
        },
        "description": "Obtiene un access token válido para el resto de endpoints"
      },
      "response": []
    },
    {
      "name": "2 - Listar bancos (España)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "url": {
          "raw": "https://bankaccountdata.gocardless.com/api/v2/institutions/?country=ES",
          "protocol": "https",
          "host": [
            "bankaccountdata",
            "gocardless",
            "com"
          ],
          "path": [
            "api",
            "v2",
            "institutions",
            ""
          ],
          "query": [
            {
              "key": "country",
              "value": "ES"
            }
          ]
        },
        "description": "Lista instituciones financieras disponibles en España."
      },
      "response": []
    },
    {
