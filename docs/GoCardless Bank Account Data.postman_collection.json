              "if (response.access) {",
              "  pm.collectionVariables.set(\"agreement_id\", response.id);",
              "  console.log(\"agreement_id guardado en collectionVariables\");",
              "} else {",
              "  console.log(\"No se ha encontrado agreement_id en la respuesta\");",
              "}",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"max_historical_days\": 90,\n  \"access_valid_for_days\": 30,\n  \"institution_id\": \"CAIXABANK_CAIXESBB\"\n}"
        },
        "url": {
          "raw": "https://bankaccountdata.gocardless.com/api/v2/agreements/enduser/",
